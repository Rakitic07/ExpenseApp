# ----------------------------------------------------------------------------
# Spendly environment variables
# Copy this file to `.env` (local) and set the same values in Vercel Project
# Settings -> Environment Variables (Production + Preview).
# NEVER commit the real .env file. It is git-ignored.
# ----------------------------------------------------------------------------

# PostgreSQL connection string — used in PRODUCTION (Vercel) only.
# Local development uses a zero-setup SQLite file instead, so you can leave this
# as-is (or empty) when running locally.
# For production: create a free Postgres DB on https://neon.tech (or the Vercel
# "Storage" tab) and set this in Vercel -> Settings -> Environment Variables.
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign session cookies (JWT). Generate a long random value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-secret"
